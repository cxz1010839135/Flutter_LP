<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX 主产品定义。文件列表由 heat 根据 staging 目录生成（Files.wxs）。
  构建：scripts/build_msi.ps1
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <?define ProductName = "领鹏智能" ?>
  <?define Manufacturer = "领鹏智能" ?>
  <?define InstallFolderName = "LPRobot" ?>

  <Product
    Id="*"
    Name="$(var.ProductName)"
    Language="2052"
    Version="$(var.ProductVersion)"
    Manufacturer="$(var.Manufacturer)"
    UpgradeCode="8F2E9C1A-4B5D-4E6F-9A0B-1C2D3E4F5A6B">
    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Description="$(var.ProductName) Windows 安装包"
      Comments="领鹏机器人上位机" />

    <MajorUpgrade
      Schedule="afterInstallInitialize"
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="已安装更高版本，请先卸载后再安装。" />

    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="$(var.ProjectDir)windows\runner\resources\app_icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPNOMODIFY" Value="1" />

    <Feature Id="ProductFeature" Title="$(var.ProductName)" Level="1">
      <ComponentGroupRef Id="MainApplicationFiles" />
      <ComponentRef Id="ApplicationShortcuts" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="ManufacturerFolder" Name="Lingpeng">
          <Directory Id="INSTALLFOLDER" Name="$(var.InstallFolderName)" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="$(var.ProductName)" />
      </Directory>
      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="ApplicationShortcuts" Guid="C3D4E5F6-A7B8-4901-CDEF-123456789ABC">
        <Shortcut
          Id="StartMenuShortcut"
          Name="$(var.ProductName)"
          Description="$(var.ProductName)"
          Target="[INSTALLFOLDER]flutter_application_1.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <Shortcut
          Id="DesktopShortcut"
          Name="$(var.ProductName)"
          Description="$(var.ProductName)"
          Target="[INSTALLFOLDER]flutter_application_1.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanUpStartMenu" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Lingpeng\LPRobot"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.ProjectDir)installer\wix\License.rtf" />
  </Product>
</Wix>
