<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- 国内/离线环境常无法访问漏洞审计 API，会触发 NU1900；不影响 WiX 包还原与 MSI 构建。 -->
  <config>
    <add key="audit" value="false" />
  </config>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
