<?xml version="1.0" encoding="utf-8"?>
<!-- Blockly 本地 shelf 服务 (127.0.0.1) 与机器人控制器内网 HTTP 均需明文 -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
